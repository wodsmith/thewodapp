{
	"name": "wodsmith-monorepo",
	"private": true,
	"scripts": {
		"build": "turbo build",
		"dev": "turbo dev",
		"dev:stripe": "stripe listen --forward-to localhost:3000/api/webhooks/stripe",
		"lint": "turbo lint",
		"format": "turbo format",
		"check": "turbo check",
		"type-check": "turbo type-check",
		"test": "turbo test",
		"test:coverage": "turbo test:coverage",
		"db:generate": "turbo db:generate",
		"db:studio": "turbo db:studio",
		"db:migrate:dev": "turbo db:migrate:dev",
		"db:migrate:prod": "turbo db:migrate:prod",
		"email:dev": "turbo email:dev",
		"ts:clean": "find . -name '.tsbuildinfo' -type f -delete"
	},
	"devDependencies": {
		"turbo": "^2.5.8"
	},
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
